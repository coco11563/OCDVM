<!doctype html><html><head><meta charset="utf-8">
<title>OCDVM — Oracle Dynamic Valuation</title>
<style>
body{font-family:system-ui,-apple-system,sans-serif;margin:2rem auto;max-width:960px;padding:0 1rem;color:#1a1a1a;line-height:1.5}
h1{font-size:1.5rem} h2{font-size:1.15rem;margin-top:2rem;border-bottom:1px solid #e2e2e2;padding-bottom:.3rem}
h3{font-size:1rem;margin:1rem 0 .2rem} table{border-collapse:collapse;margin:.5rem 0}
td,th{padding:.4rem .8rem;border:1px solid #ccc;text-align:left} th{background:#f6f6f6}
.commentary p{margin:.2rem 0 .8rem} .grid{display:flex;flex-wrap:wrap;gap:1rem}
figure{margin:0;max-width:460px} figure img{width:100%;border:1px solid #eee;border-radius:4px}
figcaption{font-size:.8rem;color:#555;margin-top:.2rem} small{color:#777}
</style></head><body>
<h1>Oracle (ORCL) — Dynamic SOTP Valuation · {{ r.quarter }}</h1>
<table>
<tr><th>Target</th><td>${{ '%.2f'|format(r.target) }}</td>
    <th>Prob-weighted</th><td>${{ '%.2f'|format(r.pw_price) }}</td></tr>
<tr><th>Current</th><td>${{ '%.2f'|format(r.current_price) }}</td>
    <th>Expected return</th><td>{{ '%.1f'|format(r.expected_return*100) }}%</td></tr>
<tr><th>α (Neo-cloud weight)</th><td>{{ '%.2f'|format(r.alpha) }}</td>
    <th>CEI / regime</th><td>{{ '%.2f'|format(r.cei or 0) }} / {{ r.regime }}</td></tr>
<tr><th>M_Neo × Q</th><td>{{ '%.1f'|format(r.m_neo) }}× × {{ '%.2f'|format(r.q) }}</td>
    <th>Model EV vs Market EV</th><td>${{ '%.0f'|format(r.ev_total/1000) }}B / ${{ '%.0f'|format(r.market_ev/1000) }}B</td></tr>
</table>

<h2>Interpretation</h2>
{{ commentary|safe }}

{% set caps = {
  'sotp':'Sum-of-the-parts: Legacy vs OCI enterprise value',
  'scenarios':'Bear / Base / Bull target vs current price',
  'sensitivity':'Target price vs OCI growth × Neo multiple',
  'alpha_cei':'Migration weight α and Capital Efficiency Index',
  'factor_breakdown':'How α is built: each factor’s Neo-ness score and weight',
  'peer_multiples':'Peer EV/Sales vs revenue-weighted median M_Neo',
  'ev_reconciliation':'Model EV (Legacy+OCI) vs the market’s EV',
  'fundamental_trends':'Oracle revenue, CapEx and RPO trajectories (SEC)',
  'price_history':'ORCL price vs model target and Bear–Bull band',
  'capacity_path':'Bottom-up MW build: modeled vs note-headline new OCI',
  'capacity_roic':'Pre-tax ROIC vs build-cost/MW × revenue/MW (red box = note)',
  'capacity_cei':'Projected CEI vs build-cost/MW × revenue/MW (>1 → migration)'
} %}
<h2>Model outputs</h2>
<div class="grid">
{% for k in ['sotp','scenarios','sensitivity','alpha_cei'] %}{% if k in pngs %}
<figure><img src="{{ pngs[k] }}" alt="{{ k }}"><figcaption>{{ caps[k] }}</figcaption></figure>
{% endif %}{% endfor %}
</div>

<h2>Corroborating evidence</h2>
<div class="grid">
{% for k in ['factor_breakdown','peer_multiples','ev_reconciliation','fundamental_trends','price_history'] %}{% if k in pngs %}
<figure><img src="{{ pngs[k] }}" alt="{{ k }}"><figcaption>{{ caps[k] }}</figcaption></figure>
{% endif %}{% endfor %}
</div>

{% if 'capacity_path' in pngs %}
<h2>Bottom-up capacity cross-check</h2>
<div class="grid">
{% for k in ['capacity_path','capacity_roic','capacity_cei'] %}{% if k in pngs %}
<figure><img src="{{ pngs[k] }}" alt="{{ k }}"><figcaption>{{ caps[k] }}</figcaption></figure>
{% endif %}{% endfor %}
</div>
{% endif %}

<p><small>Generated by OCDVM. OCI EBITDA/margins are modeled, not reported by Oracle;
OCI revenue/growth/RPO/CapEx are reported. Not investment advice.</small></p>
</body></html>
