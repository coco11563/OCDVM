<!doctype html><html><head><meta charset="utf-8">
<title>OCDVM — Oracle Dynamic Valuation</title>
<style>body{font-family:system-ui;margin:2rem;max-width:1000px}
table{border-collapse:collapse}td,th{padding:.4rem .8rem;border:1px solid #ccc}
img{max-width:480px;margin:.5rem}</style></head><body>
<h1>Oracle (ORCL) — Dynamic SOTP Valuation · {{ r.quarter }}</h1>
<table>
<tr><th>Target</th><td>${{ '%.2f'|format(r.target) }}</td>
    <th>Prob-weighted</th><td>${{ '%.2f'|format(r.pw_price) }}</td></tr>
<tr><th>Current</th><td>${{ '%.2f'|format(r.current_price) }}</td>
    <th>Expected return</th><td>{{ '%.1f'|format(r.expected_return*100) }}%</td></tr>
<tr><th>α</th><td>{{ '%.2f'|format(r.alpha) }}</td>
    <th>CEI / regime</th><td>{{ '%.2f'|format(r.cei or 0) }} / {{ r.regime }}</td></tr>
<tr><th>M_Neo</th><td>{{ '%.1f'|format(r.m_neo) }}×</td>
    <th>Q</th><td>{{ '%.2f'|format(r.q) }}</td></tr>
</table>
{% for k, v in pngs.items() %}<img src="{{ v }}" alt="{{ k }}">{% endfor %}
<p><small>Generated by OCDVM. OCI EBITDA/margins are modeled, not reported by Oracle.</small></p>
</body></html>
